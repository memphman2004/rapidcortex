{
  "name": "rapid-cortex",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "test": "vitest run",
    "test:ci": "npm run test:security && npx vitest run --exclude 'apps/api/src/__tests__/security/**'",
    "test:security": "npx vitest run apps/api/src/__tests__/security",
    "security:scan-secrets": "node scripts/check-repo-secrets.mjs",
    "security:audit": "npm audit --audit-level=moderate --json > npm-audit-report.json",
    "security:audit:fix": "npm audit fix",
    "security:licenses": "npx license-checker-rseidelsohn --onlyAllow 'MIT;ISC;BSD-2-Clause;BSD-3-Clause;Apache-2.0;0BSD;Unlicense;CC0-1.0;Python-2.0' --excludePrivatePackages",
    "build": "npm run build -w rapid-cortex-shared && npm run build -w rapid-cortex-maps && npm run build -w rapid-cortex-protocols && npm run build -w rapid-cortex-integrations && npm run build -w rapid-cortex-security && npm run build -w rapid-cortex-api && npm run build -w rapid-cortex-web",
    "dev": "npm run dev -w rapid-cortex-api",
    "dev:web": "npm run dev -w rapid-cortex-web",
    "dev:web:webpack": "npm run dev:webpack -w rapid-cortex-web",
    "build:web": "npm run build -w rapid-cortex-web",
    "build:marketing": "bash scripts/build-marketing.sh",
    "verify:marketing": "bash scripts/verify-marketing-static.sh",
    "sync:marketing": "bash scripts/sync-marketing-to-s3.sh",
    "deploy:marketing": "bash scripts/deploy-marketing.sh",
    "start:web": "npm run start -w rapid-cortex-web",
    "lint:web": "npm run lint -w rapid-cortex-web",
    "aws:setup": "bash scripts/aws-setup.sh",
    "aws:print-web-env": "bash scripts/print-stack-outputs-for-web.sh",
    "deploy:api": "bash scripts/deploy.sh",
    "deploy:web:ssr": "bash scripts/deploy-web-ssr.sh",
    "docker:push:ssr": "bash scripts/push-web-ssr-image.sh",
    "smoke:api": "bash scripts/post-deploy-smoke.sh",
    "smoke:api:synthetic": "bash scripts/synthetic-api-health.sh",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "package:customer-docs": "node scripts/package-customer-program-docs.mjs",
    "validate:docs-readiness": "bash scripts/validate-docs-deployment-readiness.sh",
    "audit:next-deploy-blockers": "node scripts/audit-next-deploy-blockers.mjs",
    "validate:iam": "bash scripts/validate-iam-policies.sh",
    "validate:aws-environment": "bash scripts/validate-aws-environment.sh",
    "seed:rc-admin": "tsx scripts/create-rc-admin.ts",
    "seed:superadmin": "tsx scripts/create-rc-admin.ts",
    "seed:role-test-users": "npx tsx scripts/seed-role-test-users.ts",
    "seed:campus:cognito": "CREATE_CAMPUS_TEST_USERS=1 bash scripts/setup-campus-cognito-roles.sh",
    "seed:test-agency": "tsx scripts/seed-test-agency-dev.ts",
    "seed:venue:test-agency": "tsx scripts/archive/seed-venue-test-facility-dev.ts",
    "onboard:pilot-customer": "tsx scripts/onboard-pilot-customer.ts",
    "typecheck": "npm run build -w rapid-cortex-shared && npm run build -w rapid-cortex-security && tsc -p apps/web/tsconfig.json --noEmit",
    "sam:validate": "sam validate --template-file infra/template.yaml --lint",
    "sam:build": "sam build --template-file infra/template.yaml",
    "test:validation": "vitest run apps/web/__tests__/validation",
    "validate:quick": "bash scripts/validation-checklist.sh && npm run build && npm run typecheck && npm run test:validation",
    "validate:all": "bash scripts/run-comprehensive-validation.sh",
    "validate:report": "bash scripts/generate-validation-report.sh",
    "pilot:smoke": "tsx scripts/pilot-smoke-test.ts",
    "security:g3": "tsx scripts/g3-security-smoke-test.ts",
    "language-support:smoke": "tsx scripts/language-support-smoke-test.ts",
    "test:g1": "npx vitest run apps/api/src/__tests__/security/jwt-validation.test.ts",
    "test:g2": "npx vitest run apps/web/lib/rapid-cortex/cad/__tests__/adapter-integration.test.ts apps/web/lib/rapid-cortex/cad/__tests__/staging-cad-read-adapter.test.ts",
    "validate:all-gates": "bash scripts/readiness-gates-check.sh",
    "deploy:hospital:dev": "./scripts/hospital/deploy-hospital-module.sh dev",
    "deploy:hospital:staging": "./scripts/hospital/deploy-hospital-module.sh staging",
    "deploy:hospital:prod": "./scripts/hospital/deploy-hospital-module.sh prod",
    "seed:hospitals:dev": "./scripts/hospital/seed-hospital-data.sh dev",
    "seed:hospitals:staging": "./scripts/hospital/seed-hospital-data.sh staging",
    "seed:hospitals:prod": "./scripts/hospital/seed-hospital-data.sh prod",
    "test:hospital:dev": "./scripts/hospital/test-hospital-api.sh dev",
    "test:hospital:staging": "./scripts/hospital/test-hospital-api.sh staging",
    "test:hospital:prod": "./scripts/hospital/test-hospital-api.sh prod",
    "create:hospital-user": "./scripts/hospital/create-hospital-user.sh",
    "aggregate:metrics": "./scripts/hospital/aggregate-daily-metrics.sh",
    "test:hl7": "./scripts/hospital/test-hl7-listener.sh dev localhost"
  },
  "devDependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.699.0",
    "@aws-sdk/client-dynamodb": "^3.699.0",
    "@aws-sdk/lib-dynamodb": "^3.699.0",
    "prettier": "^3.5.3",
    "tsx": "^4.20.0",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "fast-xml-parser": "^5.7.0"
  }
}
