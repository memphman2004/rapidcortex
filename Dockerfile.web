# syntax=docker/dockerfile:1
# Monorepo-aware Next.js image for ECS (built in CI / CodeBuild — no Docker Desktop locally).
# Use AWS Public ECR mirror to avoid Docker Hub anonymous rate limits (HTTP 429) in CodeBuild.
# Target linux/amd64 — ECS prod task definition must use runtimePlatform X86_64 (see deploy notes).
# Bump npm then `npm ci --legacy-peer-deps` so CI matches lockfiles produced locally with --legacy-peer-deps
# (strict `npm ci` can reject the same tree npm 10.x resolves with legacy peer handling).
FROM --platform=linux/amd64 public.ecr.aws/docker/library/node:20-bookworm-slim AS deps
WORKDIR /app

COPY package.json package-lock.json ./
COPY tsconfig.base.json ./
COPY packages ./packages/
COPY apps ./apps/

RUN npm install -g npm@latest && npm ci --legacy-peer-deps

FROM deps AS builder
WORKDIR /app

ARG NEXT_PUBLIC_API_BASE_URL
ARG NEXT_PUBLIC_API_BASE
ARG NEXT_PUBLIC_API_BASE_2
ARG NEXT_PUBLIC_API_BASE_3
ARG NEXT_PUBLIC_API_BASE_4
ARG NEXT_PUBLIC_API_BASE_5
ARG NEXT_PUBLIC_COGNITO_REGION
ARG NEXT_PUBLIC_COGNITO_USER_POOL_ID
ARG NEXT_PUBLIC_COGNITO_CLIENT_ID
ARG NEXT_PUBLIC_COGNITO_DOMAIN
ARG NEXT_PUBLIC_SITE_URL
ARG NEXT_PUBLIC_APP_ORIGIN
ARG NEXT_PUBLIC_MARKETING_SITE_URL
ARG NEXT_PUBLIC_MAC_DOWNLOAD_URL
ARG NEXT_PUBLIC_WINDOWS_DOWNLOAD_URL
ARG NEXT_PUBLIC_RC_LITE_DOCS_URL
ARG NEXT_PUBLIC_RC_LITE_API_URL
ARG NEXT_PUBLIC_ENABLE_DOWNLOADS
ARG NEXT_PUBLIC_ENABLE_RC_LITE
ARG NEXT_PUBLIC_ENABLE_LIVE_VIDEO
ARG NEXT_PUBLIC_ENABLE_CONNECT_RING
ARG NEXT_PUBLIC_ENABLE_CONNECT_RING_AVAILABLE_CAMERAS
ARG NEXT_PUBLIC_ENABLE_CONNECT_RING_EMERGENCY_REQUESTS
ARG NEXT_PUBLIC_ENABLE_SILENT_TEXT
ARG NEXT_PUBLIC_EXTERNAL_STATUS_PAGE_URL
ARG NEXT_PUBLIC_ENABLE_HOSPITAL_ROUTING
ARG NEXT_PUBLIC_ENABLE_HOSPITAL_PORTAL
ARG NEXT_PUBLIC_ENABLE_EMERGENCY_CONNECT
ARG NEXT_PUBLIC_GA_MEASUREMENT_ID
ARG APP_ENV=production
ARG APP_VERSION=unknown

ENV NEXT_TELEMETRY_DISABLED=1
ENV NEXT_PUBLIC_API_BASE_URL=${NEXT_PUBLIC_API_BASE_URL}
ENV NEXT_PUBLIC_API_BASE=${NEXT_PUBLIC_API_BASE}
ENV NEXT_PUBLIC_API_BASE_2=${NEXT_PUBLIC_API_BASE_2}
ENV NEXT_PUBLIC_API_BASE_3=${NEXT_PUBLIC_API_BASE_3}
ENV NEXT_PUBLIC_API_BASE_4=${NEXT_PUBLIC_API_BASE_4}
ENV NEXT_PUBLIC_API_BASE_5=${NEXT_PUBLIC_API_BASE_5}
ENV NEXT_PUBLIC_COGNITO_REGION=${NEXT_PUBLIC_COGNITO_REGION}
ENV NEXT_PUBLIC_COGNITO_USER_POOL_ID=${NEXT_PUBLIC_COGNITO_USER_POOL_ID}
ENV NEXT_PUBLIC_COGNITO_CLIENT_ID=${NEXT_PUBLIC_COGNITO_CLIENT_ID}
ENV NEXT_PUBLIC_COGNITO_DOMAIN=${NEXT_PUBLIC_COGNITO_DOMAIN}
ENV NEXT_PUBLIC_SITE_URL=${NEXT_PUBLIC_SITE_URL}
ENV NEXT_PUBLIC_APP_ORIGIN=${NEXT_PUBLIC_APP_ORIGIN}
ENV NEXT_PUBLIC_MARKETING_SITE_URL=${NEXT_PUBLIC_MARKETING_SITE_URL}
ENV NEXT_PUBLIC_MAC_DOWNLOAD_URL=${NEXT_PUBLIC_MAC_DOWNLOAD_URL}
ENV NEXT_PUBLIC_WINDOWS_DOWNLOAD_URL=${NEXT_PUBLIC_WINDOWS_DOWNLOAD_URL}
ENV NEXT_PUBLIC_RC_LITE_DOCS_URL=${NEXT_PUBLIC_RC_LITE_DOCS_URL}
ENV NEXT_PUBLIC_RC_LITE_API_URL=${NEXT_PUBLIC_RC_LITE_API_URL}
ENV NEXT_PUBLIC_ENABLE_DOWNLOADS=${NEXT_PUBLIC_ENABLE_DOWNLOADS}
ENV NEXT_PUBLIC_ENABLE_RC_LITE=${NEXT_PUBLIC_ENABLE_RC_LITE}
ENV NEXT_PUBLIC_ENABLE_LIVE_VIDEO=${NEXT_PUBLIC_ENABLE_LIVE_VIDEO}
ENV NEXT_PUBLIC_ENABLE_CONNECT_RING=${NEXT_PUBLIC_ENABLE_CONNECT_RING}
ENV NEXT_PUBLIC_ENABLE_CONNECT_RING_AVAILABLE_CAMERAS=${NEXT_PUBLIC_ENABLE_CONNECT_RING_AVAILABLE_CAMERAS}
ENV NEXT_PUBLIC_ENABLE_CONNECT_RING_EMERGENCY_REQUESTS=${NEXT_PUBLIC_ENABLE_CONNECT_RING_EMERGENCY_REQUESTS}
ENV NEXT_PUBLIC_ENABLE_SILENT_TEXT=${NEXT_PUBLIC_ENABLE_SILENT_TEXT}
ENV NEXT_PUBLIC_EXTERNAL_STATUS_PAGE_URL=${NEXT_PUBLIC_EXTERNAL_STATUS_PAGE_URL}
ENV NEXT_PUBLIC_ENABLE_HOSPITAL_ROUTING=${NEXT_PUBLIC_ENABLE_HOSPITAL_ROUTING}
ENV NEXT_PUBLIC_ENABLE_HOSPITAL_PORTAL=${NEXT_PUBLIC_ENABLE_HOSPITAL_PORTAL}
ENV NEXT_PUBLIC_ENABLE_EMERGENCY_CONNECT=${NEXT_PUBLIC_ENABLE_EMERGENCY_CONNECT}
ENV NEXT_PUBLIC_GA_MEASUREMENT_ID=${NEXT_PUBLIC_GA_MEASUREMENT_ID}
ENV NEXT_PUBLIC_APP_ENV=${APP_ENV}
ENV APP_ENV=${APP_ENV}
ENV APP_VERSION=${APP_VERSION}

RUN npm run build -w rapid-cortex-shared \
  && npm run build -w rapid-cortex-maps \
  && npm run build -w rapid-cortex-protocols \
  && npm run build -w rapid-cortex-integrations \
  && npm run build -w rapid-cortex-security \
  && npm run build -w rapid-cortex-web

FROM --platform=linux/amd64 public.ecr.aws/docker/library/node:20-bookworm-slim AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

ARG APP_ENV=production
ARG APP_VERSION=unknown
ENV APP_ENV=${APP_ENV}
ENV APP_VERSION=${APP_VERSION}

RUN apt-get update -y \
  && apt-get install -y --no-install-recommends ca-certificates curl \
  && rm -rf /var/lib/apt/lists/*

COPY --from=builder /app/apps/web/.next/standalone ./
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder /app/apps/web/public ./apps/web/public

EXPOSE 3000

# Aligns with `GET /api/health/web` (apps/web/app/api/health/web/route.ts) and ALB `HealthCheckPath` in web-ssr-fargate.
# Use node (always in image) — prod images may not ship curl/wget in the slim runner.
HEALTHCHECK --interval=30s --timeout=10s --start-period=90s --retries=3 \
  CMD node -e "fetch('http://127.0.0.1:3000/api/health/web').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"

CMD ["node", "apps/web/server.js"]
