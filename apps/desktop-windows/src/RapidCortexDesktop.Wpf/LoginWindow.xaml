<Window x:Class="RapidCortex.Desktop.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rapid Cortex"
        Height="640"
        Width="960"
        MinHeight="600"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#0a0f1a"
        FontFamily="Segoe UI"
        ResizeMode="CanResize"
        WindowStyle="SingleBorderWindow">
  <Window.Resources>
    <Style x:Key="PrimarySignInButton" TargetType="Button">
      <Setter Property="Background" Value="#2563eb"/>
      <Setter Property="Foreground" Value="#f9fafb"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Padding" Value="16,12"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    CornerRadius="8"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#3b82f6"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Bd" Property="Background" Value="#1e3a8a"/>
                <Setter Property="Foreground" Value="#9ca3af"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="GhostIconButton" TargetType="Button">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="#9ca3af"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Padding" Value="4"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="2*"/>
      <ColumnDefinition Width="3*"/>
    </Grid.ColumnDefinitions>

    <!-- Branding -->
    <Border Grid.Column="0" Background="#0a0f1a">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="320" Margin="32">
          <Border Width="72" Height="72" CornerRadius="12" Background="#1e293b" HorizontalAlignment="Center">
            <Viewbox Margin="14">
              <Canvas Width="24" Height="24">
                <Path Fill="#60a5fa"
                      Data="M12,2 L20,6 V12 C20,17 16,20 12,22 C8,20 4,17 4,12 V6 Z"/>
              </Canvas>
            </Viewbox>
          </Border>
          <TextBlock Text="Rapid Cortex"
                     FontSize="28"
                     FontWeight="Bold"
                     Foreground="#f9fafb"
                     HorizontalAlignment="Center"
                     Margin="0,20,0,0"/>
          <TextBlock Text="Real-Time AI Intelligence for Emergency Response"
                     FontSize="13"
                     Foreground="#6b7280"
                     TextWrapping="Wrap"
                     TextAlignment="Center"
                     Margin="0,12,0,0"/>
        </StackPanel>
        <TextBlock Grid.Row="1"
                   Text="CJIS-Aligned  |  End-to-End Encrypted  |  911 Ready"
                   FontSize="11"
                   Foreground="#6b7280"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   Margin="24,0,24,28"/>
      </Grid>
    </Border>

    <!-- Sign in -->
    <Border Grid.Column="1" Background="#111827">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="VersionText"
                   Grid.Row="0"
                   HorizontalAlignment="Right"
                   Margin="24,20,24,0"
                   FontSize="11"
                   Foreground="#6b7280"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <Grid VerticalAlignment="Center" MaxWidth="400" Margin="40,24" HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="24"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Welcome back" FontSize="28" FontWeight="Bold" Foreground="#f9fafb"/>
            <TextBlock Grid.Row="1"
                       Text="Sign in to access your secure agency workspace"
                       FontSize="13"
                       Foreground="#6b7280"
                       TextWrapping="Wrap"
                       Margin="0,8,0,0"/>

            <Button x:Name="SignInButton"
                    Grid.Row="3"
                    Style="{StaticResource PrimarySignInButton}"
                    Height="44"
                    HorizontalAlignment="Stretch"
                    Click="OnSignInClick">
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Viewbox Width="18" Height="18" Margin="0,0,10,0" VerticalAlignment="Center">
                  <Canvas Width="24" Height="24">
                    <Path Fill="#f9fafb"
                          Data="M12,2 L20,6 V12 C20,17 16,20 12,22 C8,20 4,17 4,12 V6 Z"/>
                  </Canvas>
                </Viewbox>
                <TextBlock Text="Sign in with Agency SSO" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <Border x:Name="InfoBanner"
                    Grid.Row="4"
                    Margin="0,12,0,0"
                    Padding="12,10"
                    CornerRadius="8"
                    BorderBrush="#1f2937"
                    BorderThickness="1"
                    Background="#0f172a"
                    Visibility="Collapsed">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="InfoBannerText" Grid.Column="0" Foreground="#9ca3af" FontSize="12" TextWrapping="Wrap"/>
                <Button Grid.Column="1" Style="{StaticResource GhostIconButton}" Content="&#xE711;" FontFamily="Segoe MDL2 Assets" Click="OnDismissInfo" VerticalAlignment="Top"/>
              </Grid>
            </Border>

            <Border x:Name="ErrorBanner"
                    Grid.Row="5"
                    Margin="0,12,0,0"
                    Padding="12,10"
                    CornerRadius="8"
                    BorderBrush="#ef4444"
                    BorderThickness="1"
                    Background="#1f1517"
                    Visibility="Collapsed">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="ErrorBannerText" Grid.Column="0" Foreground="#f9fafb" FontSize="12" TextWrapping="Wrap"/>
                <Button Grid.Column="1" Style="{StaticResource GhostIconButton}" Content="&#xE711;" FontFamily="Segoe MDL2 Assets" Foreground="#fca5a5" Click="OnDismissError" VerticalAlignment="Top"/>
              </Grid>
            </Border>

            <Grid x:Name="LoadingPanel" Grid.Row="6" Margin="0,16,0,0" Visibility="Collapsed">
              <StackPanel HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Height="4" Width="220" Foreground="#2563eb" Background="#1f2937"/>
                <TextBlock x:Name="LoadingMessageText"
                           Text="Connecting to identity provider..."
                           FontSize="12"
                           Foreground="#6b7280"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>
              </StackPanel>
            </Grid>

            <StackPanel Grid.Row="7" Margin="0,28,0,0">
              <Grid Height="1" Background="#1f2937"/>
              <TextBlock Text="or"
                         FontSize="11"
                         Foreground="#6b7280"
                         HorizontalAlignment="Center"
                         Margin="0,-8,0,0"
                         Padding="12,0"
                         Background="#111827"/>
            </StackPanel>

            <TextBlock Grid.Row="8"
                       Margin="0,20,0,0"
                       FontSize="11"
                       Foreground="#6b7280"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Text="Access is managed by your agency administrator"/>

            <TextBlock Grid.Row="9" Margin="0,12,0,0" FontSize="11" Foreground="#6b7280" HorizontalAlignment="Center">
              <Hyperlink NavigateUri="mailto:support@rapidcortex.us"
                         Foreground="#60a5fa"
                         RequestNavigate="OnSupportNavigate">
                Need help? Contact support
              </Hyperlink>
            </TextBlock>
          </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
          <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE785;" FontSize="12" Foreground="#6b7280" Margin="0,0,6,0" VerticalAlignment="Center"/>
          <TextBlock Text="256-bit encrypted · Session secured by AWS Cognito"
                     FontSize="11"
                     Foreground="#6b7280"
                     VerticalAlignment="Center"/>
        </StackPanel>
      </Grid>
    </Border>

  </Grid>
</Window>
