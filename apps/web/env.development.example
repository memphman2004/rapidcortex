# Copy to .env.development for local Next dev (.env* is gitignored except .env.example).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development

NEXT_PUBLIC_API_BASE_URL=
API_UPSTREAM_BASE=https://REPLACE.execute-api.us-east-1.amazonaws.com

NEXT_PUBLIC_COGNITO_REGION=us-east-1
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_CLIENT_ID=
NEXT_PUBLIC_COGNITO_DOMAIN=

NEXT_PUBLIC_MAC_DOWNLOAD_URL=https://downloads.rapidcortex.us/mac/latest/RapidCortex.dmg
NEXT_PUBLIC_WINDOWS_DOWNLOAD_URL=https://downloads.rapidcortex.us/windows/latest/RapidCortexSetup.exe
NEXT_PUBLIC_RC_LITE_DOCS_URL=
NEXT_PUBLIC_RC_LITE_API_URL=https://api.rapidcortex.us/api/v1

NEXT_PUBLIC_ENABLE_DOWNLOADS=true
NEXT_PUBLIC_ENABLE_RC_LITE=true

APP_ENV=development
APP_VERSION=0.0.0-dev
