NEXT_PUBLIC_SITE_URL=https://www.rapidcortex.us
NEXT_PUBLIC_REPORT_ORIGIN=https://report.rapidcortex.us
NEXT_PUBLIC_REPORT_ORIGIN_STAGING=https://staging.report.rapidcortex.us
NEXT_PUBLIC_REPORT_ORIGIN_DEV=https://dev.report.rapidcortex.us

# Optional (API Lambda / SES HTML email): overrides origin for hosted logo URLs (default: NEXT_PUBLIC_SITE_URL or https://www.rapidcortex.us).
# PUBLIC_MARKETING_SITE_URL=https://www.rapidcortex.us

# After CSP report-only burn-in, set to 1 to send Content-Security-Policy (enforcement) instead of Report-Only.
# NEXT_PUBLIC_CSP_ENFORCE=1

# Primary workspace slug (`https://your-host/{slug}/login`). Use your operational tenant on production — not the academy slug unless this deployment is demo-only.
NEXT_PUBLIC_DEFAULT_JURISDICTION_SLUG=example-city

# Reserved slug label for scripted academy/sales scenarios. Must match the path segment you use for walkthroughs (often `demo`).
NEXT_PUBLIC_DEMO_JURISDICTION_SLUG=demo

# `false` on production customer sites: hides `/…/demo`, side-nav Demo, and returns 404 for scripted demo routes. Omit in local dev (defaults to enabled outside production builds).
# NEXT_PUBLIC_ENABLE_DEMO_SCRIPTED_CONTENT=false

NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_0z6tA6WBs
NEXT_PUBLIC_COGNITO_CLIENT_ID=7moi6sgc2uf4o31omgvo77h3v5
NEXT_PUBLIC_COGNITO_NATIVE_CLIENT_ID=3nkemnrffspnaa0ikp2un6koh0
NEXT_PUBLIC_COGNITO_REGION=us-east-1
NEXT_PUBLIC_COGNITO_DOMAIN=https://rapidcortex-dev-158961537080.auth.us-east-1.amazoncognito.com
NEXT_PUBLIC_NATIVE_REDIRECT_URI=rapidcortex://oauth/callback
NEXT_PUBLIC_NATIVE_LOGOUT_URI=rapidcortex://logout/callback

# Native/desktop OAuth (PKCE). SAM output `NativeUserPoolClientId` — separate from web client above.
# COGNITO_NATIVE_CLIENT_ID=3nkemnrffspnaa0ikp2un6koh0

# Server-side aliases for Next route handlers/middleware (same values as NEXT_PUBLIC_* for dev).
COGNITO_USER_POOL_ID=us-east-1_0z6tA6WBs
COGNITO_CLIENT_ID=7moi6sgc2uf4o31omgvo77h3v5
COGNITO_REGION=us-east-1
COGNITO_DOMAIN=https://rapidcortex-dev-158961537080.auth.us-east-1.amazoncognito.com
COGNITO_TOKEN_ENDPOINT=https://rapidcortex-dev-158961537080.auth.us-east-1.amazoncognito.com/oauth2/token

NEXT_PUBLIC_AUTH_PROXY=1

# When `1`, edge middleware calls `/api/backend/api/agency/network-policy-check` and redirects
# blocked users to `/access-restricted`. Requires API `NETWORK_ACCESS_ENFORCEMENT=true` for real denials.
# NEXT_PUBLIC_ENABLE_NETWORK_ACCESS_GATE=1

# Network policy admin UI (IP allowlist + shift hours pages).
# NEXT_PUBLIC_ENABLE_NETWORK_ACCESS=1

API_UPSTREAM_BASE=https://cv1z1us095.execute-api.us-east-1.amazonaws.com
API_UPSTREAM_BASE_2=https://xatbi3w5f5.execute-api.us-east-1.amazonaws.com

# Downloads & marketing chrome (marketing header/footer respects feature flags).

NEXT_PUBLIC_MAC_DOWNLOAD_URL=https://downloads.rapidcortex.us/mac/latest/RapidCortex.dmg
NEXT_PUBLIC_WINDOWS_DOWNLOAD_URL=https://downloads.rapidcortex.us/windows/latest/RapidCortexSetup.exe
NEXT_PUBLIC_RC_LITE_DOCS_URL=
NEXT_PUBLIC_RC_LITE_API_URL=https://api.rapidcortex.us/api/v1

NEXT_PUBLIC_CUSTOMER_LOGIN_URL=

# Prefer https://status.… here to link the footer “Status page” externally; omit to use baked-in `/status`.
# NEXT_PUBLIC_EXTERNAL_STATUS_PAGE_URL=https://status.rapidcortex.us

NEXT_PUBLIC_ENABLE_DOWNLOADS=true
NEXT_PUBLIC_ENABLE_RC_LITE=true

NEXT_PUBLIC_APP_ENV=development

# Container/runtime metadata surfaced by `GET /api/health/web` (set in ECS task / Docker build; often prod even when NEXT_PUBLIC_APP_ENV is development for local UI).
# APP_ENV=production
# APP_VERSION=1.0.0

# Browser bundle (same hosts as API Gateway when not using custom domains):
NEXT_PUBLIC_API_BASE=https://cv1z1us095.execute-api.us-east-1.amazonaws.com
NEXT_PUBLIC_API_BASE_2=https://xatbi3w5f5.execute-api.us-east-1.amazonaws.com
# NEXT_PUBLIC_API_BASE_URL=https://api.rapidcortex.us
# Custom domains (alternative to execute-api URLs above): api.rapidcortex.us + stack-2 host per `scripts/env-web-ssr-prod.sh`.

# Public self-signup is OFF by default.
# Enable both flags only for controlled internal testing.
NEXT_PUBLIC_ENABLE_PUBLIC_SIGNUP=0
ENABLE_PUBLIC_SIGNUP=false

# --- CAD pilot (controlled read-only / shadow). Defaults are fail-closed. ---
# CAD_INTEGRATION_MODE=read_only reads staging mock data unless CAD_VENDOR_NAME includes "motorola" (credentials still required remotely).
CAD_INTEGRATION_MODE=read_only
CAD_VENDOR_NAME=
# Optional Motorola / generic agency default when enriching vendor payloads.
# CAD_DEFAULT_AGENCY_ID=staging-agency-001
# CAD write-back stays OFF unless explicitly enabled (UI + API both fail-closed).
CAD_WRITEBACK_ENABLED=false
NEXT_PUBLIC_ENABLE_CAD_WRITEBACK=0

# --- CAD vendor-neutral adapter framework (server-only in apps/web) ---
# RAPID_CORTEX_CAD_MODE: disabled | read_only | assisted_writeback
RAPID_CORTEX_CAD_MODE=mock
CAD_VENDOR=mock
CAD_API_BASE_URL=
CAD_CLIENT_ID=
CAD_CLIENT_SECRET=
CAD_API_KEY=
CAD_TIMEOUT_MS=10000
CAD_MOCK_FAILURE_RATE=0

# --- Pilot / test-agency QA (local dev) ---
# When unset in development, `isPilotTestModeEnabled()` defaults to on unless set to 0.
# Forces every `NEXT_PUBLIC_ENABLE_*` gate on via apps/web/lib/runtime-flags.ts.
# NEXT_PUBLIC_ENABLE_PILOT_TEST_MODE=1
# Or: source scripts/env-web-pilot-test.sh before npm run dev:web

# --- Hospital module (Stack 2: capacity, routing, MCI, analytics, hospital portal) ---
NEXT_PUBLIC_ENABLE_HOSPITAL_ROUTING=1
NEXT_PUBLIC_ENABLE_HOSPITAL_PORTAL=1
# --- Vertical product surfaces + platform UI controls ---
NEXT_PUBLIC_ENABLE_VERTICAL_CAMPUS=1
NEXT_PUBLIC_ENABLE_VERTICAL_VENUE=1
NEXT_PUBLIC_ENABLE_ADDON_MANAGEMENT=1
NEXT_PUBLIC_ENABLE_VERTICAL_BADGE=1
# Hospital staff UI: https://your-host/hospital-portal

# --- Operational feature flags (default ON when unset — see apps/web/lib/runtime-flags.ts) ---
# Explicitly set to 0/false to disable a surface. CAD write-back defaults OFF.
NEXT_PUBLIC_ENABLE_QA_SCORING=1
NEXT_PUBLIC_ENABLE_REPORTS=1
NEXT_PUBLIC_ENABLE_SLA_BACKLOG=1
NEXT_PUBLIC_ENABLE_WAR_ROOMS=1
NEXT_PUBLIC_ENABLE_STAKEHOLDER_PAGES=1
NEXT_PUBLIC_ENABLE_POST_INCIDENT_REVIEWS=1
NEXT_PUBLIC_ENABLE_INCIDENT_MEDIA=1
NEXT_PUBLIC_ENABLE_CALLER_MEDIA=1
NEXT_PUBLIC_ENABLE_LIVE_VIDEO=1
NEXT_PUBLIC_ENABLE_SOP_PROTOCOL_AI=1
NEXT_PUBLIC_ENABLE_NON_EMERGENCY_TRIAGE=1
NEXT_PUBLIC_ENABLE_FIELD_CONFIDENCE=1
NEXT_PUBLIC_ENABLE_DISPATCHER_WELLNESS=1
NEXT_PUBLIC_ENABLE_CALLER_CARD=1
NEXT_PUBLIC_ENABLE_SUPERVISOR_PERFORMANCE=1
NEXT_PUBLIC_ENABLE_ADMIN_ANALYTICS=1
NEXT_PUBLIC_ENABLE_CROSS_JURISDICTION_SHARES=1
NEXT_PUBLIC_ENABLE_SEO_INTELLIGENCE=1
NEXT_PUBLIC_ENABLE_DECEPTION_SHIELD_UI=1
NEXT_PUBLIC_ENABLE_CAD_ADMIN=1
NEXT_PUBLIC_ENABLE_CAD_WRITEBACK=0
NEXT_PUBLIC_ENABLE_SILENT_TEXT=1
NEXT_PUBLIC_ENABLE_PINPOINT=1
NEXT_PUBLIC_ENABLE_SURGE=1
NEXT_PUBLIC_ENABLE_EMERGENCY_CONNECT=1
NEXT_PUBLIC_ENABLE_CALL_CONTROL=1
NEXT_PUBLIC_ENABLE_NETWORK_ACCESS=1
NEXT_PUBLIC_ENABLE_VENUE_INTELLIGENCE=1
NEXT_PUBLIC_ENABLE_LOCATIONS_QR_ADMIN=1
NEXT_PUBLIC_ENABLE_CONNECT_RING=true
NEXT_PUBLIC_ENABLE_CONNECT_RING_AVAILABLE_CAMERAS=true
NEXT_PUBLIC_ENABLE_CONNECT_RING_EMERGENCY_REQUESTS=true

# --- Mobile operational auth (console / Hosted UI entry) ---
# Phones are blocked when enforcement runs. Tablets are blocked by default; set BLOCK_TABLET_AUTH=false to allow tablet-class user agents (still subject to DISABLE_MOBILE_AUTH).
# When DISABLE_MOBILE_AUTH is unset: production defaults to enforcing block; development defaults to allowing (easier local QA).
# DISABLE_MOBILE_AUTH=true
# NEXT_PUBLIC_DISABLE_MOBILE_AUTH mirrors server toggle for edge cases (optional client-side signals).
# BLOCK_TABLET_AUTH=true
