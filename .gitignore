# See https://git-scm.com/docs/gitignore

# dependencies
/node_modules
# Generated by scripts/deploy.sh for SAM (file: local tarballs; do not commit)
apps/api/vendor-packs/
# SAM CLI build artifact cache (sam build --build-dir default)
.rapid-cortex-sam-build/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# packaged customer documentation (npm run package:customer-docs)
/dist/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# MapKit JS credentials (Electron desktop)
packages/desktop/keys/*.p8
packages/desktop/.env.mapkit

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.deploy.dev.example

# Local SSR deploy helpers (contain/surface account identifiers; source only)
scripts/env-web-ssr-*.sh
# Local API deploy env (account ARNs / stack output fetch; source only)
scripts/env-api-dev.sh
# Local macOS Developer ID + notarytool credentials (never commit)
scripts/env-mac-signing.sh

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# dependencies
node_modules/
apps/api/node_modules/

# Next.js / build output
.next/
apps/web/.next/
apps/web/out/
out/
dist/
build/

# AWS SAM / temp
.aws-sam/
infra/.aws-sam/
.sam-build-dir/
.tmp-make-artifacts/

# environment / secrets
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
*.p12
rapidcortex-prod-*.json

# editor/system
.DS_Store
.vscode/
.cursor/

# archives/artifacts
*.zip
*.tgz
artifacts/


# additional local/sensitive files
*.env
*.local
*.log

# macOS app builds
*.app/

# security scanner cache/config if local only
.semgrep/

# random/temp
ziKUSoeO


# Office temp files
~$*

# compiled/published desktop output
apps/desktop-windows/src/RapidCortexDesktop.Wpf/publish/

# production/staging local config files
apps/desktop-windows/src/RapidCortexDesktop.Wpf/appsettings.Production.json
apps/desktop-windows/src/RapidCortexDesktop.Wpf/appsettings.Staging.json
apps/desktop-windows/src/RapidCortexDesktop.Wpf/appsettings.Development.json
