# =============================================================================
# Rapid Cortex — environment template (copy to `.env.local` in `apps/web/`
# and configure Lambda / SAM env for `apps/api/` separately).
# =============================================================================

# --- apps/web (Next.js) — prefix NEXT_PUBLIC_ is exposed to the browser
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# First path segment for product URLs: https://www.rapidcortex.us/<slug>/dashboard
# Production: one slug per city / town / county site (e.g. columbus, franklin-county).
# Fallback in code is `example-city` if unset — override for every real deployment.
NEXT_PUBLIC_DEFAULT_JURISDICTION_SLUG=example-city

# Local/sales only: in-browser mock incident queue when API is not wired (see docs/NON_GOALS.md §5).
# NEXT_PUBLIC_OFFLINE_DEMO_MODE=1

# Optional: show scripted transcript chunk controls on /dashboard when API is live (pilot default: omit).
# NEXT_PUBLIC_ENABLE_TRAINING_TRANSCRIPT_STREAM=1

# F1 QA scoring UI (supervisor queue, admin templates, dashboard QA panel). Must match API ENABLE_QA_SCORING in deploy.
# NEXT_PUBLIC_ENABLE_QA_SCORING=1

# F2 caller media (SMS upload link + gallery on dashboard). Must match API ENABLE_INCIDENT_MEDIA.
# NEXT_PUBLIC_ENABLE_INCIDENT_MEDIA=1

# Silent Text (SMS link → web text chat for unsafe-to-speak callers). Must match API
# ENABLE_SILENT_TEXT and a configured SMS provider (Twilio secret ARN or AWS SNS sandbox-out).
NEXT_PUBLIC_ENABLE_SILENT_TEXT=false

# LiveLocation / Pinpoint (SMS GPS link). Must match API ENABLE_PINPOINT.
NEXT_PUBLIC_ENABLE_PINPOINT=false

# Optional: hosted docs root (e.g. https://github.com/YourOrg/repo/blob/main/docs) for Admin → Pilot hub + marketing links.
# NEXT_PUBLIC_DOCUMENTATION_BASE_URL=https://github.com/YourOrg/your-repo/blob/main/docs

# Shown in the header environment badge (local | preview | production | custom)
# NEXT_PUBLIC_APP_ENV=local

# --- Recommended operational stack (same-origin cookies → BFF → API) ---
# NEXT_PUBLIC_AUTH_PROXY=1
# API_UPSTREAM_BASE=https://xxxx.execute-api.us-east-1.amazonaws.com
#
# Cognito (must match the pool attached to the API JWT authorizer)
# NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_xxxx
# NEXT_PUBLIC_COGNITO_CLIENT_ID=xxxx
# NEXT_PUBLIC_COGNITO_REGION=us-east-1
# NEXT_PUBLIC_COGNITO_DOMAIN=https://your-prefix.auth.us-east-1.amazoncognito.com
# NEXT_PUBLIC_NATIVE_REDIRECT_URI=rapidcortex://oauth/callback
# NEXT_PUBLIC_NATIVE_LOGOUT_URI=rapidcortex://logout/callback
# COGNITO_TOKEN_ENDPOINT=https://your-prefix.auth.us-east-1.amazoncognito.com/oauth2/token
# Server-only: set when the app client has a client secret (Sign up / confirm use it)
# COGNITO_CLIENT_SECRET=
#
# Direct browser → API (requires a client-visible bearer token; not used by the
# current cookie sign-in flow — leave unset when using NEXT_PUBLIC_AUTH_PROXY=1)
# NEXT_PUBLIC_API_BASE=https://xxxx.execute-api.us-east-1.amazonaws.com
#
# Square Web Payments SDK (browser-safe identifiers, not secrets)
# NEXT_PUBLIC_SQUARE_APPLICATION_ID=sq0idp-...
# NEXT_PUBLIC_SQUARE_LOCATION_ID=L...

# --- apps/api (Lambda) — set via SAM template parameters / AWS console
# INCIDENTS_TABLE=
# TRANSCRIPTS_TABLE=
# ANALYSES_TABLE=
# AUDIT_TABLE=
# OPENAI_API_KEY=
# (etc.)

# --- apps/api — Silent Text / LiveLocation public links ---
# Public origin where caller-facing token pages are served (`https://www.rapidcortex.us`
# by default in SAM; override locally to your tunnel host). Same value works for both surfaces.
SILENT_TEXT_PUBLIC_BASE_URL=https://www.rapidcortex.us
PINPOINT_PUBLIC_BASE_URL=https://www.rapidcortex.us

# Server-side feature flags read by apps/api `env.ts`. Both default to "false" — only enable
# after Twilio creds are loaded into the `rapid-cortex/twilio` Secrets Manager entry.
# ENABLE_SILENT_TEXT=false
# ENABLE_PINPOINT=false

# --- apps/api — SMS transport (Twilio or AWS End User Messaging / SNS) ---
# Both Silent Text and Pinpoint share `apps/api/src/services/sms/smsProviderFactory.ts`.
# Credentials live in Secrets Manager — never paste raw values here.
#   `INCIDENT_MEDIA_TWILIO_SECRET_ARN` (or `TWILIO_SECRET_ARN`) — JSON: accountSid, authToken,
#     fromE164 (or messagingServiceSid). Pinpoint, incident media, and Silent Text reuse it.
#   `SMS_PROVIDER` — auto | twilio | aws | mock (defaults: dev=mock, staging/prod=auto)
#   `SMS_PRIMARY_PROVIDER` — twilio | aws (which side `auto` tries first)
# INCIDENT_MEDIA_TWILIO_SECRET_ARN=arn:aws:secretsmanager:us-east-1:...:secret:rapid-cortex/twilio-...
# SMS_PROVIDER=auto
# SMS_PRIMARY_PROVIDER=twilio
# SQUARE_ACCESS_TOKEN=
# SQUARE_APPLICATION_ID=
# SQUARE_LOCATION_ID=
# SQUARE_ENVIRONMENT=sandbox
# SQUARE_WEBHOOK_SIGNATURE_KEY=

# --- apps/api — AI analysis (Lambda / SAM) ---
# Provider chain (legacy FALLBACK_PROVIDER / SECONDARY_FALLBACK_PROVIDER still map to
# secondary / tertiary when the new names are unset).
# PRIMARY_PROVIDER=openai|anthropic|bedrock|mock|off
# SECONDARY_PROVIDER=...
# TERTIARY_PROVIDER=...|off
# AI_ENABLE_FALLBACKS=true|false
# AI_STORE_PROVIDER_METADATA=true|false
# AI_PROMPT_VERSION=dispatch-triage-v1
# AI_REQUEST_TIMEOUT_MS=55000
# AI_MAX_RETRIES_PER_PROVIDER=1
# AI_ANALYSIS_DEBOUNCE_SECONDS=0
# AI_MAX_ANALYZE_REQUESTS_PER_INCIDENT_PER_HOUR=120
# AI_SKIP_IF_TRANSCRIPT_UNCHANGED=true|false
# AI_ANALYSIS_IN_FLIGHT_LEASE_SECONDS=90
# OPENAI_API_KEY= (dev) or OPENAI_API_KEY_SECRET_ARN=arn:aws:secretsmanager:...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL_PRIMARY=gpt-4o-mini
# OPENAI_MODEL_SECONDARY=gpt-4o-mini
# OPENAI_MODEL_TERTIARY=gpt-4o-mini
# ANTHROPIC_API_KEY= or ANTHROPIC_API_KEY_SECRET_ARN=
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL_PRIMARY=claude-3-5-haiku-20241022
# BEDROCK_REGION=us-east-1
# BEDROCK_MODEL_PRIMARY=anthropic.claude-3-5-haiku-20241022-v1:0
# AUTO_ANALYZE_EVERY_N_SEGMENTS=0
# AI_ALLOW_MOCK_ONLY_IN_PROD=true  (Lambda only; allows mock-only AI when DEPLOYMENT_STAGE is staging/prod — sandboxes)
#
# --- F1 QA scoring (Lambda; SAM sets tables when enabled) ---
# ENABLE_QA_SCORING=true|false
# ENABLE_QA_SCORE_AFTER_ANALYSIS=true  (run QA scoring for draft/failed sessions after successful /analyze)
# QA_SESSIONS_TABLE=
# QA_TEMPLATES_TABLE=
# QA_SCORING_MOCK=true  (structured scorer without Bedrock)
# QA_BEDROCK_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0
#
# --- F2 incident caller media (Lambda + Dynamo + S3 prefix incident-media/) ---
# ENABLE_INCIDENT_MEDIA=true|false
# INCIDENT_MEDIA_TABLE=
# INCIDENT_MEDIA_PUBLIC_BASE_URL=https://www.rapidcortex.us  (SMS links must reach this host’s /media/upload/…)
# INCIDENT_MEDIA_TOKEN_TTL_MINUTES=120
# INCIDENT_MEDIA_UPLOAD_URL_TTL_SECONDS=900
# INCIDENT_MEDIA_MAX_UPLOAD_BYTES=52428800
# INCIDENT_MEDIA_SNS_DIRECT=1  (SNS direct SMS; otherwise log-only unless Twilio secret is wired + IAM)
# INCIDENT_MEDIA_SMS_MOCK=true
# SMS_PROVIDER=twilio|aws|auto|mock
# SMS_PRIMARY_PROVIDER=twilio|aws  (used when SMS_PROVIDER=auto)
# TWILIO_SECRET_ARN=  (preferred) or INCIDENT_MEDIA_TWILIO_SECRET_ARN=  (legacy alias)
#   Secrets Manager JSON only — never put accountSid / authToken / messagingServiceSid in plain env in production.
#   Supported shapes: { accountSid, messagingServiceSid } with API key OR { accountSid, authToken, messagingServiceSid }
#   OR legacy { accountSid, authToken, fromE164 }. Lambdas need GetSecretValue on that ARN.
# Optional operator / runbook alignment for the approved toll-free (E.164). The API sends via Messaging Service
# or fromE164 from the secret; these are documentation-only unless you wire custom tooling to read them:
# TWILIO_MESSAGING_PHONE_NUMBER=+18556293679
# TWILIO_SMS_FROM=+18556293679
# TWILIO_MMS_FROM=+18556293679
# INCIDENT_MEDIA_TWILIO_SECRET_ARN=  (legacy name; use TWILIO_SECRET_ARN when possible)
#
# --- Multilingual voice (Lambda) — see docs/MULTILINGUAL_CALL_PIPELINE.md ---
# LANGUAGE_SESSIONS_TABLE= (set by SAM; required for /language-session/* and /audio-chunks)
# SUPPORTED_CALL_LANGUAGES=en,es,zh,tl,vi,ar,fr,ko,ru,pt
# ENABLE_TRANSLATION_TO_ENGLISH=true
# ENABLE_INTERPRETER_ESCALATION_FLAG=true
# AUTO_FEED_TRANSLATED_TRANSCRIPTS_TO_ANALYSIS=true
# LANGUAGE_DETECTION_MIN_CONFIDENCE=0.65
# STT_MIN_CONFIDENCE=0.55
# TRANSLATION_MIN_CONFIDENCE=0.6
# PROVIDER_REQUEST_TIMEOUT_MS=55000
# PROVIDER_MAX_RETRIES=2
# PROVIDER_ENABLE_FALLBACKS=true
# MULTILINGUAL_STRICT_VALIDATION=true|false (SAM sets per DeploymentStage; override on Lambda if needed)
# Vendor tiers: azure | google | aws | mock | off  (legacy aws_comprehend / aws_translate → aws)
# PRIMARY_LANGUAGE_DETECTOR=azure
# SECONDARY_LANGUAGE_DETECTOR=google
# TERTIARY_LANGUAGE_DETECTOR=aws
# PRIMARY_STT_PROVIDER=azure
# SECONDARY_STT_PROVIDER=google
# TERTIARY_STT_PROVIDER=aws
# PRIMARY_TRANSLATION_PROVIDER=azure
# SECONDARY_TRANSLATION_PROVIDER=google
# TERTIARY_TRANSLATION_PROVIDER=aws
# AZURE_SPEECH_KEY= (dev) or AZURE_SPEECH_KEY_SECRET_ARN=
# AZURE_SPEECH_REGION=eastus
# AZURE_SPEECH_ENDPOINT= (optional)
# AZURE_SPEECH_STT_MODEL=azure-stt-default
# AZURE_TRANSLATION_KEY= (optional; defaults to speech key)
# AZURE_TRANSLATION_KEY_SECRET_ARN=
# AZURE_TRANSLATION_REGION=eastus
# AZURE_TRANSLATION_MODEL=azure-translator
# GOOGLE_CLOUD_PROJECT_ID=
# GOOGLE_APPLICATION_CREDENTIALS_SECRET_ARN=
# GOOGLE_APPLICATION_CREDENTIALS_JSON= (local only; full service account JSON)
# GOOGLE_STT_MODEL=default
# GOOGLE_TRANSLATION_MODEL=google-translate-v2
# AWS_TRANSCRIBE_REGION=us-east-1
# AWS_TRANSLATE_REGION=us-east-1
# AWS_COMPREHEND_REGION=us-east-1
# ASSETS_BUCKET= (required when AWS Transcribe is enabled — same bucket SAM sets)
# CALL_STREAM_CHUNK_MS=2000
# MAX_TRANSCRIPT_REORDER_WINDOW_MS=30000

# --- Phase 2 (F4 SOP / F3 triage / F5 wellness) — match SAM Globals + client flags ---
# ENABLE_SOP_PROTOCOL_AI=true
# SOP_DETECT_EVERY_N_SEGMENTS=5
# SOP_DETECTION_MOCK=false
# ENABLE_NON_EMERGENCY_TRIAGE=true
# TRIAGE_DETECT_EVERY_N_SEGMENTS=5
# TRIAGE_MOCK=false
# ENABLE_DISPATCHER_WELLNESS=true
# NEXT_PUBLIC_ENABLE_SOP_PROTOCOL_AI=1
# NEXT_PUBLIC_ENABLE_NON_EMERGENCY_TRIAGE=1
# NEXT_PUBLIC_ENABLE_DISPATCHER_WELLNESS=1

# --- Rapid Cortex Connect — Ring (server-side; flags off until Ring app certification) ---
# RING_PARTNERSHIP_ENABLED=false
# ENABLE_CONNECT_RING=false
# ENABLE_CONNECT_RING_AVAILABLE_CAMERAS=false
# ENABLE_CONNECT_RING_EMERGENCY_REQUESTS=false
# RING_CREDENTIALS_SECRET_ARN=   # Secrets Manager JSON: clientId, clientSecret, hmacKey
# RING_PARTNER_TOKEN_SECRET_ARN= # alias of RING_CREDENTIALS_SECRET_ARN (webhook adapter)
# RING_REDIRECT_URI=https://api.rapidcortex.us/api/integrations/ring/callback
# RING_ACCOUNT_LINK_URL=https://www.rapidcortex.us/connect/ring/link
# RING_WEBHOOK_URL=https://api.rapidcortex.us/api/integrations/ring/webhook
# RING_SECRETS_PREFIX=rapid-cortex/connect/ring
# RING_KMS_KEY_ID=   # optional CMK for Ring token secrets in Secrets Manager

# --- Vendor-neutral CAD adapter framework (server-side) ---
# RAPID_CORTEX_CAD_MODE=mock|disabled|read_only|assisted_writeback
# CAD_VENDOR=mock|motorola|centralsquare|tyler|hexagon|generic
# CAD_API_BASE_URL=
# CAD_CLIENT_ID=
# CAD_CLIENT_SECRET=
# CAD_API_KEY=
# CAD_TIMEOUT_MS=10000
# CAD_WRITEBACK_ENABLED=false
# CAD_MOCK_FAILURE_RATE=0
